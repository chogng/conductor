{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "baseUrl": ".",
    "rootDir": ".",
    "outDir": "desktop-dist",
    "paths": {
      "cs/*": ["./src/cs/*"],
      "src/*": ["./src/*"]
    },
    "types": ["node"],
    "strict": false,
    "skipLibCheck": true
  },
  "include": [
    "desktop/**/*.ts",
    "src/bootstrap-*.ts",
    "src/cs/code/electron-main/**/*.ts",
    "src/cs/code/electron-utility/**/*.ts",
    "src/cs/platform/storage/electron-main/**/*.ts",
    "src/cs/platform/theme/electron-main/**/*.ts",
    "src/cs/platform/windows/electron-main/**/*.ts",
    "src/cs/workbench/services/storage/common/**/*.ts",
    "src/cs/workbench/services/storage/electron-main/**/*.ts"
  ]
}
