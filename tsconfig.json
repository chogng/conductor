{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "strict": true,
    "experimentalDecorators": true,
    "allowJs": true,
    "checkJs": false,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["vite/client"],
    "paths": {
      "cs/*": ["./src/cs/*"],
      "src/*": ["./src/*"]
    }
  },
  "include": ["src"],
  "exclude": ["src/cs/code/electron-main", "src/cs/code/electron-utility"]
}
