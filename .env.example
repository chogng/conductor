# Frontend (Vite)
# Optional websocket endpoint override; empty means same-origin.
VITE_WS_URL=

# OriginBridge (local desktop helper) needs a real, absolute API base URL.
# In dev with Vite proxy, set this to your backend (e.g. http://127.0.0.1:3001/api).
# In production (backend serves dist), you can leave it empty.
VITE_ORIGINBRIDGE_API_BASE_URL=

# Device Analysis preview renderer
# 0 = legacy table renderer (default), 1 = experimental canvas renderer
VITE_DA_PREVIEW_CANVAS=0

# Desktop updater (Electron main process)
# Optional override for updater feed URL (normally use packaged GitHub Releases provider).
CONDUCTOR_UPDATE_URL=
