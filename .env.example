# Frontend (Vite)
# Use these to point the UI to a different backend.
VITE_API_BASE_URL=/api
# Empty means same-origin (recommended; works with Vite proxy + backend-served dist)
VITE_WS_URL=

# OriginBridge (local desktop helper) needs a real, absolute API base URL.
# In dev with Vite proxy, set this to your backend (e.g. http://127.0.0.1:3001/api).
# In production (backend serves dist), you can leave it empty.
VITE_ORIGINBRIDGE_API_BASE_URL=

# Optional: enable mock frontend (bypasses backend)
VITE_MOCK_API=false

# Mock auth (only used when VITE_MOCK_API=true)
# Auto-login a mock user (skip the login page)
VITE_MOCK_AUTO_LOGIN=true
# Choose which mock user to use: admin | user
VITE_MOCK_USER=admin
