{
  "name": "conductor",
  "private": true,
  "version": "1.5.19",
  "type": "module",
  "main": "out/desktop/src/main.js",
  "scripts": {
    "preinstall": "node --experimental-strip-types build/npm/preinstall.ts",
    "postinstall": "node --experimental-strip-types build/npm/postinstall.ts",
    "deps:ensure": "node --experimental-strip-types build/npm/fast-install.ts",
    "sync:nls": "node --experimental-strip-types build/lib/nls.ts",
    "verify:icons": "node --experimental-strip-types build/win32/verify-icons.ts",
    "verify:retired-user-storage": "node scripts/verify-retired-user-storage.mjs",
    "verify:nls": "node --experimental-strip-types build/lib/nls.ts",
    "generate:icons": "node scripts/run-powershell.mjs scripts/generate-icons.ps1",
    "verify:conductor-rs-artifacts": "node scripts/verify-conductor-rs-artifacts.mjs",
    "verify:conductor-rs-smoke": "node scripts/verify-conductor-rs-smoke.mjs",
    "verify:rust-table-models-parity": "node --experimental-strip-types scripts/verify-rust-table-models-parity.mjs",
    "dev": "npm run dev:vite --",
    "dev:vite": "npm run deps:ensure && vite --configLoader runner",
    "dev:desktop": "node --experimental-strip-types build/npm/fast-install.ts --silent && node --experimental-strip-types scripts/dev-desktop.ts",
    "build:py-worker": "node scripts/run-powershell.mjs scripts/build-py-worker.ps1",
    "build:conductor-rs": "node scripts/build-conductor-rs.mjs",
    "build:xlsx-wasm": "node scripts/run-powershell.mjs scripts/build-rs-xlsx-wasm.ps1",
    "build:worker": "npm run build:py-worker && npm run build:conductor-rs",
    "verify:py-worker": "node scripts/verify-py-worker.mjs",
    "verify:rust-analysis": "npm run verify:rust-ss-auto",
    "verify:rust-ss-auto": "node --experimental-strip-types --import ./scripts/lib/register-src-alias-loader.mjs scripts/bench-device-analysis-phase3.mjs prepare && powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/bench-rs-phase3.ps1 -RequestSet prepare && node --experimental-strip-types --import ./scripts/lib/register-src-alias-loader.mjs scripts/bench-device-analysis-phase3.mjs plan-process && powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/bench-rs-phase3.ps1 -RequestSet process && node --experimental-strip-types --import ./scripts/lib/register-src-alias-loader.mjs scripts/verify-rust-ss-auto-compat.mjs prepare && powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/verify-rs-ss-auto.ps1 && node --experimental-strip-types --import ./scripts/lib/register-src-alias-loader.mjs scripts/verify-rust-ss-auto-compat.mjs compare",
    "verify:rust-origin-export": "node --experimental-strip-types --import ./scripts/lib/register-src-alias-loader.mjs scripts/verify-rust-origin-export-compat.mjs prepare && powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/verify-rs-origin-export.ps1 -Mode prepare && node --experimental-strip-types --import ./scripts/lib/register-src-alias-loader.mjs scripts/verify-rust-origin-export-compat.mjs plan-process && powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/verify-rs-origin-export.ps1 -Mode process && node --experimental-strip-types --import ./scripts/lib/register-src-alias-loader.mjs scripts/verify-rust-origin-export-compat.mjs plan && powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/verify-rs-origin-export.ps1 -Mode export && node --experimental-strip-types --import ./scripts/lib/register-src-alias-loader.mjs scripts/verify-rust-origin-export-compat.mjs compare",
    "bench:analysis-cache": "node --experimental-strip-types --import ./scripts/lib/register-src-alias-loader.mjs scripts/bench-analysis-cache-budget.mjs",
    "bench:import:data": "node scripts/prepare-import-bench-data.mjs",
    "bench:import:fixtures": "node test/fixtures/data-import/stress/generate-stress-fixtures.mjs",
    "bench:import:generated": "npm run bench:import:data && node scripts/bench-device-analysis-import.mjs .build/bench/import-data",
    "bench:phase3": "node --experimental-strip-types --import ./scripts/lib/register-src-alias-loader.mjs scripts/bench-device-analysis-phase3.mjs prepare && powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/bench-rs-phase3.ps1 -RequestSet prepare && node --experimental-strip-types --import ./scripts/lib/register-src-alias-loader.mjs scripts/bench-device-analysis-phase3.mjs plan-process && powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/bench-rs-phase3.ps1 -RequestSet process && node --experimental-strip-types --import ./scripts/lib/register-src-alias-loader.mjs scripts/bench-device-analysis-phase3.mjs prepare-rust-analysis && powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/bench-rs-phase3.ps1 -RequestSet analysis && node --experimental-strip-types --import ./scripts/lib/register-src-alias-loader.mjs scripts/bench-device-analysis-phase3.mjs analyze",
    "build:desktop:core": "node --experimental-strip-types scripts/build-desktop-core.ts",
    "build:web:desktop": "npm run build:xlsx-wasm && vite build --base ./",
    "build": "npm run build:xlsx-wasm && vite build --base ./",
    "dist:web": "npm run build",
    "lint": "eslint .",
    "test:unit:target": "tsc -p src/tsconfig.test.json && node test/unit/node/target.js",
    "test:table": "npm run test:unit:target -- src/cs/base/test/common/performance.test.ts src/cs/workbench/contrib/performance/test/browser/performanceMeasurements.test.ts src/cs/workbench/contrib/table/test/browser/tableCommands.test.ts src/cs/workbench/contrib/table/test/browser/tableWidget.test.ts src/cs/workbench/services/table/test/browser/tableService.test.ts src/cs/workbench/services/table/test/browser/tableModel.test.ts src/cs/workbench/services/table/test/browser/tableStructureParserService.test.ts src/cs/workbench/services/table/test/browser/tableViewModel.test.ts src/cs/workbench/services/table/test/common/table.test.ts src/cs/workbench/services/table/test/common/tableFormatService.test.ts src/cs/workbench/services/table/test/common/tableStructureParser.test.ts src/cs/workbench/services/tableFile/test/common/tableFileReader.test.ts",
    "test:review": "npm run test:unit:target -- src/cs/workbench/services/dataResource/test/browser/dataResourceService.test.ts src/cs/workbench/services/dataResource/test/browser/dataResourceEvaluation.test.ts src/cs/workbench/services/review/test/common/review.test.ts src/cs/workbench/services/review/test/common/reviewCandidate.test.ts src/cs/workbench/services/review/test/browser/reviewService.test.ts",
    "test:unit": "tsc -p src/tsconfig.test.json && node test/unit/node/index.js",
    "test:integration:browser": "node test/integration/browser/folderImport.test.mjs",
    "test:template-apply-performance-trace": "node test/integration/browser/templateApplyPerformanceTrace.test.mjs",
    "test:desktop-core": "npm run build:desktop:core && mocha --ui tdd test/integration/node/originRunner.test.mjs",
    "trace:desktop-startup": "node scripts/trace-desktop-startup.mjs",
    "test:unit:browser": "node test/unit/browser/index.js",
    "preview:titlebar-update": "node test/unit/browser/preview.js titlebar-update",
    "test:origin-runner": "npm run build:desktop:core && mocha --ui tdd test/integration/node/originRunner.test.mjs",
    "typecheck": "tsc -p src/tsconfig.json --noEmit && tsc -p src/tsconfig.desktop.json --noEmit && tsc -p src/tsconfig.scripts.json --noEmit && npm run verify:nls && npm run verify:conductor-rs-artifacts",
    "preview": "vite preview",
    "build:desktop:bundle": "node scripts/build-desktop.mjs",
    "build:desktop": "npm run generate:icons && npm run verify:icons && npm run build:desktop:bundle",
    "pack:desktop": "npm run build:desktop && npm run verify:py-worker && electron-builder --dir",
    "dist:desktop": "npm run build:desktop && npm run verify:py-worker && electron-builder",
    "dist:desktop:store": "npm run build:desktop && npm run verify:py-worker && node --experimental-strip-types build/win32/build-appx.ts",
    "dist:desktop:oneclick": "node scripts/run-powershell.mjs scripts/pack-desktop-oneclick.ps1",
    "dist:desktop:update-debug": "node scripts/run-powershell.mjs scripts/pack-desktop-update-debug.ps1",
    "pack:desktop:oneclick": "node scripts/run-powershell.mjs scripts/pack-desktop-oneclick.ps1 -DirOnly",
    "verify:auto-update-config": "node --experimental-strip-types build/win32/verify-auto-update-config.ts",
    "dist:desktop:publish": "node scripts/run-powershell.mjs scripts/release-desktop-local.ps1",
    "release:desktop:local": "node scripts/run-powershell.mjs scripts/release-desktop-local.ps1"
  },
  "dependencies": {
    "@chogng/lxicons": "^1.0.19",
    "electron-updater": "^6.8.3",
    "fflate": "^0.8.3",
    "markdown-it": "^14.2.0",
    "yauzl": "^3.4.0",
    "yazl": "^3.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.60.0",
    "@types/markdown-it": "^14.1.2",
    "@types/mocha": "^10.0.10",
    "@types/papaparse": "^5.5.2",
    "@types/yauzl": "^3.4.0",
    "@types/yazl": "^3.3.1",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "autoprefixer": "^10.4.22",
    "electron": "^42.2.0",
    "electron-builder": "^26.0.12",
    "eslint": "^9.39.1",
    "globals": "^16.5.0",
    "mocha": "^11.7.6",
    "papaparse": "^5.5.3",
    "postcss": "^8.5.6",
    "typescript": "^5.9.3",
    "vite": "^7.2.4"
  },
  "build": {
    "appId": "com.conductor.desktop",
    "productName": "Conductor Studio",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "compression": "maximum",
    "electronLanguages": [
      "en-US",
      "zh-CN"
    ],
    "directories": {
      "buildResources": "resources/win32",
      "output": "release"
    },
    "toolsets": {
      "winCodeSign": "1.1.0"
    },
    "files": [
      "out/desktop/**/*",
      "out/renderer/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources/bin",
        "to": "bin",
        "filter": [
          "conductor-rs",
          "conductor-rs.exe"
        ]
      },
      {
        "from": "workers/py",
        "to": "workers/py"
      },
      {
        "from": "resources/win32",
        "to": "resources/win32"
      },
      {
        "from": "resources/darwin",
        "to": "resources/darwin"
      },
      {
        "from": "resources/linux",
        "to": "resources/linux"
      }
    ],
    "asar": true,
    "removePackageScripts": true,
    "publish": [
      {
        "provider": "github",
        "owner": "chogng",
        "repo": "conductor-update",
        "releaseType": "release"
      }
    ],
    "mac": {
      "icon": "../darwin/icon.icns",
      "category": "public.app-category.utilities",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "icon": "icon.ico",
      "artifactName": "Conductor-Studio-${version}-windows-${arch}-portable.${ext}",
      "signAndEditExecutable": true,
      "target": [
        "nsis",
        "zip"
      ]
    },
    "appx": {
      "artifactName": "Conductor-Studio-${version}-windows-${arch}-store.${ext}",
      "identityName": "chogng.ConductorStudio",
      "publisher": "CN=82B0186C-891B-4B58-89CA-F57F45BC1D84",
      "displayName": "Conductor Studio",
      "publisherDisplayName": "chogng",
      "languages": [
        "en-US",
        "zh-CN"
      ]
    },
    "nsis": {
      "artifactName": "Conductor-Studio-${version}-windows-${arch}-setup.${ext}",
      "installerIcon": "icon.ico",
      "uninstallerIcon": "icon.ico",
      "installerHeaderIcon": "icon.ico",
      "installerHeader": "header.bmp",
      "installerSidebar": "sidebar.bmp",
      "uninstallerSidebar": "sidebar.bmp",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "linux": {
      "icon": "../linux/icon.png",
      "category": "Utility",
      "target": [
        "AppImage",
        "deb"
      ]
    }
  }
}
