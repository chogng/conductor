{
  "name": "device-analysis-standalone",
  "private": true,
  "version": "0.5.0",
  "type": "module",
  "main": "electron-dist/main.js",
  "scripts": {
    "make:icons": "bash scripts/make-icons-macos.sh",
    "dev": "vite",
    "dev:desktop": "npm run build:electron && node scripts/dev-electron.mjs",
    "build:origin-worker": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-origin-workers.ps1",
    "build:origin-batch-worker": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-origin-batch-worker.ps1",
    "build:origin-zip-worker": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-origin-zip-worker.ps1",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build:web": "vite build",
    "build": "vite build",
    "lint": "eslint .",
    "test:preview": "node --test --test-isolation=none src/features/device-analysis/lib/previewRowChunk.test.mjs src/features/device-analysis/lib/previewSelectionNavigation.test.mjs",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.electron.json --noEmit",
    "preview": "vite preview",
    "build:desktop": "npm run build:origin-worker && npm run build:electron && npm run build:web",
    "pack:desktop": "npm run build:desktop && electron-builder --dir",
    "dist:desktop": "npm run build:desktop && electron-builder",
    "dist:desktop:oneclick": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/pack-desktop-oneclick.ps1",
    "pack:desktop:oneclick": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/pack-desktop-oneclick.ps1 -DirOnly",
    "verify:auto-update-config": "node scripts/verify-auto-update-config.mjs",
    "dist:desktop:publish": "npm run verify:auto-update-config && npm run build:desktop && electron-builder --publish always",
    "release:desktop:local": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/release-desktop-local.ps1"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.90.16",
    "electron-updater": "^6.8.3",
    "jszip": "^3.10.1",
    "lucide-react": "^0.554.0",
    "papaparse": "^5.5.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "recharts": "^3.6.0",
    "socket.io-client": "^4.7.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.22",
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.3",
    "vite": "^7.2.4"
  },
  "build": {
    "appId": "com.appointer.deviceanalysis",
    "productName": "Device Analysis Studio",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron-dist/**/*",
      "origin/**/*",
      "package.json"
    ],
    "asar": true,
    "asarUnpack": [
      "origin/**"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "chogng",
        "repo": "Device-Analysis-Studio",
        "releaseType": "release"
      }
    ],
    "mac": {
      "icon": "build/icons/icon.icns",
      "category": "public.app-category.utilities",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "icon": "build/icons/icon.ico",
      "target": [
        "nsis",
        "zip"
      ]
    },
    "linux": {
      "icon": "build/icons/icon.png",
      "category": "Utility",
      "target": [
        "AppImage",
        "deb"
      ]
    }
  }
}
