{
  "name": "conductor",
  "private": true,
  "version": "0.5.19",
  "type": "module",
  "main": "desktop-dist/desktop/main.js",
  "scripts": {
    "verify:icons": "node scripts/verify-icons.mjs",
    "verify:nls": "node --experimental-strip-types build/lib/nls.ts",
    "generate:icons": "node scripts/run-powershell.mjs scripts/generate-icons.ps1",
    "verify:rs-worker-artifacts": "node scripts/verify-rs-worker-artifacts.mjs",
    "dev": "vite --configLoader runner",
    "dev:vite": "vite --configLoader runner",
    "dev:desktop": "npm run build:desktop:core && node --experimental-strip-types scripts/dev-desktop.ts",
    "build:py-worker": "node scripts/run-powershell.mjs scripts/build-py-worker.ps1",
    "build:rs-worker": "node scripts/run-powershell.mjs scripts/build-rs-worker.ps1",
    "build:assessment-wasm": "node scripts/run-powershell.mjs scripts/build-rs-assessment-wasm.ps1",
    "build:worker": "npm run build:py-worker && npm run build:rs-worker",
    "verify:py-worker": "node scripts/verify-py-worker.mjs",
    "verify:rust-auto-extraction": "node --experimental-strip-types scripts/verify-rust-auto-extraction-compat.mjs prepare && powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/verify-rust-auto-extraction-compat.ps1 && node --experimental-strip-types scripts/verify-rust-auto-extraction-compat.mjs compare",
    "verify:rust-analysis": "npm run verify:rust-ss-auto",
    "verify:rust-ss-auto": "node --experimental-strip-types scripts/bench-device-analysis-phase3.mjs prepare && powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/bench-device-analysis-phase3.ps1 && node --experimental-strip-types scripts/verify-rust-ss-auto-compat.mjs prepare && powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/verify-rust-ss-auto-compat.ps1 && node --experimental-strip-types scripts/verify-rust-ss-auto-compat.mjs compare",
    "verify:rust-origin-export": "node --experimental-strip-types scripts/verify-rust-origin-export-compat.mjs prepare && powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/verify-rust-origin-export-worker.ps1 -Mode process && node --experimental-strip-types scripts/verify-rust-origin-export-compat.mjs plan && powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/verify-rust-origin-export-worker.ps1 -Mode export && node --experimental-strip-types scripts/verify-rust-origin-export-compat.mjs compare",
    "bench:analysis-cache": "node scripts/bench-analysis-cache-budget.mjs",
    "bench:phase3": "node --experimental-strip-types scripts/bench-device-analysis-phase3.mjs prepare && powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/bench-device-analysis-phase3.ps1 -RequestSet process && node --experimental-strip-types scripts/bench-device-analysis-phase3.mjs prepare-rust-analysis && powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/bench-device-analysis-phase3.ps1 -RequestSet analysis && node --experimental-strip-types scripts/bench-device-analysis-phase3.mjs analyze",
    "build:desktop:core": "node scripts/build-desktop-core.mjs",
    "build:web:desktop": "npm run build:assessment-wasm && vite build --base ./",
    "build": "npm run build:assessment-wasm && vite build --base ./",
    "lint": "eslint .",
    "test:preview": "node --test --test-isolation=none src/cs/workbench/contrib/table/browser/rows/rowChunk.test.mjs src/cs/workbench/contrib/table/browser/rows/selectionNavigation.test.mjs",
    "test:unit": "node --experimental-strip-types --test --test-isolation=none src/cs/workbench/contrib/table/browser/rows/rowChunk.test.mjs src/cs/workbench/contrib/table/browser/rows/selectionNavigation.test.mjs src/cs/workbench/contrib/table/browser/rows/rustCells.test.mjs src/cs/workbench/contrib/template/test/autoTemplate.test.mjs src/cs/workbench/contrib/template/test/autoTemplatePlan.test.mjs src/cs/workbench/contrib/template/test/fileNameMatching.test.mjs src/cs/workbench/contrib/template/test/templateController.test.mjs src/cs/workbench/contrib/template/test/templateManagerUtils.test.mjs src/cs/workbench/contrib/template/test/templateRecords.test.mjs src/cs/workbench/contrib/template/test/templateSelection.test.mjs src/cs/workbench/contrib/template/test/extractionErrors.test.mjs src/cs/workbench/contrib/thumbnail/browser/thumbnailView.test.mjs src/cs/workbench/browser/layout.test.mjs src/cs/workbench/services/analysisFile/test/importFileAssessment.test.mjs src/cs/workbench/services/analysisFile/test/fileAssessment.test.mjs src/cs/workbench/contrib/plot/common/units.test.mjs src/cs/workbench/contrib/plot/browser/chartModel.test.mjs src/cs/workbench/contrib/plot/browser/chartView.test.mjs src/cs/workbench/contrib/plot/browser/mainPlotModel.test.mjs src/cs/workbench/contrib/diagnostics/common/metrics.test.mjs src/cs/workbench/contrib/diagnostics/common/analysisMath.test.mjs src/cs/workbench/contrib/diagnostics/common/vth.test.mjs src/cs/workbench/contrib/parameters/browser/parametersModel.test.mjs src/cs/workbench/contrib/parameters/browser/parametersController.test.mjs src/cs/workbench/contrib/parameters/browser/rcAnalysisModel.test.mjs src/cs/workbench/contrib/plot/browser/canvasPlot.test.mjs src/cs/workbench/contrib/export/browser/exportModel.test.mjs src/cs/workbench/contrib/export/browser/export.test.mjs",
    "test:origin-runner": "npm run build:desktop:core && node --test --test-isolation=none scripts/origin-runner.test.mjs",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.desktop.json --noEmit && tsc -p tsconfig.scripts.json --noEmit && npm run verify:nls && npm run verify:rs-worker-artifacts",
    "preview": "vite preview",
    "build:desktop": "npm run generate:icons && npm run verify:icons && node scripts/build-desktop.mjs",
    "pack:desktop": "npm run build:desktop && npm run verify:py-worker && electron-builder --dir",
    "dist:desktop": "npm run build:desktop && npm run verify:py-worker && electron-builder",
    "dist:desktop:store": "npm run build:desktop && npm run verify:py-worker && electron-builder --win appx --publish never --config.win.signAndEditExecutable=false",
    "dist:desktop:oneclick": "node scripts/run-powershell.mjs scripts/pack-desktop-oneclick.ps1",
    "pack:desktop:oneclick": "node scripts/run-powershell.mjs scripts/pack-desktop-oneclick.ps1 -DirOnly",
    "verify:auto-update-config": "node --experimental-strip-types scripts/verify-auto-update-config.ts",
    "dist:desktop:publish": "node scripts/run-powershell.mjs scripts/release-desktop-local.ps1",
    "release:desktop:local": "node scripts/run-powershell.mjs scripts/release-desktop-local.ps1"
  },
  "dependencies": {
    "@chogng/lxicon": "^1.0.3",
    "electron-updater": "^6.8.3",
    "jszip": "^3.10.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "autoprefixer": "^10.4.22",
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12",
    "eslint": "^9.39.1",
    "globals": "^16.5.0",
    "papaparse": "^5.5.3",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.3",
    "vite": "^7.2.4"
  },
  "build": {
    "appId": "com.conductor.desktop",
    "productName": "Conductor Studio",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "compression": "maximum",
    "electronLanguages": [
      "en-US",
      "zh-CN"
    ],
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "toolsets": {
      "winCodeSign": "1.1.0"
    },
    "files": [
      "dist/**/*",
      "desktop-dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "workers/rs",
        "to": "workers/rs",
        "filter": [
          "rs-worker",
          "rs-worker.exe"
        ]
      },
      {
        "from": "workers/py",
        "to": "workers/py"
      },
      {
        "from": "build/icons",
        "to": "build/icons"
      },
      {
        "from": "public/demo",
        "to": "demo"
      }
    ],
    "asar": true,
    "removePackageScripts": true,
    "publish": [
      {
        "provider": "github",
        "owner": "chogng",
        "repo": "conductor-update",
        "releaseType": "release"
      }
    ],
    "mac": {
      "icon": "build/icons/icon.icns",
      "category": "public.app-category.utilities",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "icon": "build/icons/icon.ico",
      "artifactName": "Conductor-Studio-${version}-windows-${arch}-portable.${ext}",
      "signAndEditExecutable": true,
      "target": [
        "nsis",
        "zip"
      ]
    },
    "appx": {
      "artifactName": "Conductor-Studio-${version}-windows-${arch}-store.${ext}",
      "identityName": "chogng.ConductorStudio",
      "publisher": "CN=82B0186C-891B-4B58-89CA-F57F45BC1D84",
      "displayName": "Conductor Studio",
      "publisherDisplayName": "chogng",
      "languages": [
        "en-US",
        "zh-CN"
      ]
    },
    "nsis": {
      "artifactName": "Conductor-Studio-${version}-windows-${arch}-setup.${ext}",
      "installerIcon": "build/icons/icon.ico",
      "uninstallerIcon": "build/icons/icon.ico",
      "installerHeaderIcon": "build/icons/icon.ico",
      "installerHeader": "build/installer/header.bmp",
      "installerSidebar": "build/installer/sidebar.bmp",
      "uninstallerSidebar": "build/installer/sidebar.bmp",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "linux": {
      "icon": "build/icons/icon.png",
      "category": "Utility",
      "target": [
        "AppImage",
        "deb"
      ]
    }
  }
}
