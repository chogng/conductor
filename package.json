{
  "name": "device-analysis-standalone",
  "private": true,
  "version": "0.5.4",
  "type": "module",
  "main": "desktop-dist/main.js",
  "scripts": {
    "make:icons": "bash scripts/make-icons-macos.sh",
    "dev": "vite",
    "dev:desktop": "npm run build:desktop:core && node --experimental-strip-types scripts/dev-desktop.ts",
    "build:origin-csv-worker": "node scripts/run-powershell.mjs scripts/build-origin-csv-worker.ps1",
    "verify:origin-worker": "node scripts/verify-origin-csv-worker.mjs",
    "build:desktop:core": "tsc -p tsconfig.desktop.json",
    "build:web:desktop": "vite build --base ./",
    "build": "vite build",
    "lint": "eslint .",
    "test:preview": "node --test --test-isolation=none src/features/device-analysis/data/preview/previewRowChunk.test.mjs src/features/device-analysis/data/preview/previewSelectionNavigation.test.mjs",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.desktop.json --noEmit && tsc -p tsconfig.scripts.json --noEmit",
    "preview": "vite preview",
    "build:desktop": "node scripts/build-desktop.mjs",
    "pack:desktop": "npm run build:desktop && npm run verify:origin-worker && electron-builder --dir",
    "dist:desktop": "npm run build:desktop && npm run verify:origin-worker && electron-builder",
    "dist:desktop:oneclick": "node scripts/run-powershell.mjs scripts/pack-desktop-oneclick.ps1",
    "pack:desktop:oneclick": "node scripts/run-powershell.mjs scripts/pack-desktop-oneclick.ps1 -DirOnly",
    "verify:auto-update-config": "node --experimental-strip-types scripts/verify-auto-update-config.ts",
    "dist:desktop:publish": "npm run verify:auto-update-config && npm run build:desktop && npm run verify:origin-worker && electron-builder --publish always",
    "release:desktop:local": "node scripts/run-powershell.mjs scripts/release-desktop-local.ps1"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.90.16",
    "electron-updater": "^6.8.3",
    "jszip": "^3.10.1",
    "lucide-react": "^0.554.0",
    "papaparse": "^5.5.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "recharts": "^3.6.0",
    "socket.io-client": "^4.7.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.22",
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.3",
    "vite": "^7.2.4"
  },
  "build": {
    "appId": "com.appointer.deviceanalysis",
    "productName": "Device Analysis Studio",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "compression": "maximum",
    "electronLanguages": [
      "en-US",
      "zh-CN"
    ],
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "desktop-dist/**/*",
      "origin/bin/origin-csv-worker.exe",
      "package.json"
    ],
    "asar": true,
    "asarUnpack": [
      "origin/bin/origin-csv-worker.exe"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "chogng",
        "repo": "Device-Analysis-Studio",
        "releaseType": "release"
      }
    ],
    "mac": {
      "icon": "build/icons/icon.icns",
      "category": "public.app-category.utilities",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "icon": "build/icons/icon.ico",
      "artifactName": "Device-Analysis-Studio-${version}-windows-${arch}-portable.${ext}",
      "target": [
        "nsis",
        "zip",
        "7z"
      ]
    },
    "nsis": {
      "artifactName": "Device-Analysis-Studio-${version}-windows-${arch}-setup.${ext}"
    },
    "linux": {
      "icon": "build/icons/icon.png",
      "category": "Utility",
      "target": [
        "AppImage",
        "deb"
      ]
    }
  }
}
