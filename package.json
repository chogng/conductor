{
  "name": "conductor",
  "private": true,
  "version": "0.5.10",
  "type": "module",
  "main": "desktop-dist/main.js",
  "scripts": {
    "make:icons": "bash scripts/make-icons-macos.sh",
    "dev": "vite",
    "dev:desktop": "npm run build:desktop:core && node --experimental-strip-types scripts/dev-desktop.ts",
    "build:origin-csv-worker": "node scripts/run-powershell.mjs scripts/build-origin-csv-worker.ps1",
    "build:rust-xls-converter": "node scripts/run-powershell.mjs scripts/build-rust-xls-converter.ps1",
    "verify:origin-worker": "node scripts/verify-origin-csv-worker.mjs",
    "verify:rust-auto-extraction": "node --experimental-strip-types scripts/verify-rust-auto-extraction-compat.mjs prepare && powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/verify-rust-auto-extraction-compat.ps1 && node --experimental-strip-types scripts/verify-rust-auto-extraction-compat.mjs compare",
    "verify:rust-analysis": "npm run verify:rust-ss-auto",
    "verify:rust-ss-auto": "node --experimental-strip-types scripts/bench-device-analysis-phase3.mjs prepare && powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/bench-device-analysis-phase3.ps1 && node --experimental-strip-types scripts/verify-rust-ss-auto-compat.mjs prepare && powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/verify-rust-ss-auto-compat.ps1 && node --experimental-strip-types scripts/verify-rust-ss-auto-compat.mjs compare",
    "bench:analysis-cache": "node scripts/bench-analysis-cache-budget.mjs",
    "bench:phase3": "node --experimental-strip-types scripts/bench-device-analysis-phase3.mjs prepare && powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/bench-device-analysis-phase3.ps1 -RequestSet process && node --experimental-strip-types scripts/bench-device-analysis-phase3.mjs prepare-rust-analysis && powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/bench-device-analysis-phase3.ps1 -RequestSet analysis && node --experimental-strip-types scripts/bench-device-analysis-phase3.mjs analyze",
    "build:desktop:core": "tsc -p tsconfig.desktop.json",
    "build:web:desktop": "vite build --base ./",
    "build": "vite build",
    "lint": "eslint .",
    "test:preview": "node --test --test-isolation=none src/features/device-analysis/data/preview/previewRowChunk.test.mjs src/features/device-analysis/data/preview/previewSelectionNavigation.test.mjs",
    "test:unit": "node --experimental-strip-types --test --test-isolation=none src/features/device-analysis/data/preview/previewRowChunk.test.mjs src/features/device-analysis/data/preview/previewSelectionNavigation.test.mjs src/features/device-analysis/data/preview/rustPreviewCells.test.mjs src/features/device-analysis/data/template/useTemplateManagerPreview.test.mjs src/features/device-analysis/deviceAnalysisLayout.test.mjs src/features/device-analysis/shared/lib/deviceAnalysisImportFileUtils.test.mjs src/features/device-analysis/shared/lib/fileNameFieldMatching.test.mjs src/features/device-analysis/shared/lib/deviceAnalysisCurveClassification.test.mjs src/features/device-analysis/shared/lib/deviceAnalysisAutoExtraction.test.mjs src/features/device-analysis/analysis/lib/deviceAnalysisUnits.test.mjs src/features/device-analysis/analysis/lib/deviceAnalysisMetrics.test.mjs src/features/device-analysis/analysis/lib/analysisMath.test.mjs src/features/device-analysis/analysis/lib/canvasPlotUtils.test.mjs src/features/device-analysis/analysis/lib/deviceAnalysisExport.test.mjs",
    "test:origin-runner": "npm run build:desktop:core && node --test --test-isolation=none scripts/origin-runner.test.mjs",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.desktop.json --noEmit && tsc -p tsconfig.scripts.json --noEmit",
    "preview": "vite preview",
    "build:desktop": "node scripts/build-desktop.mjs",
    "pack:desktop": "npm run build:desktop && npm run verify:origin-worker && electron-builder --dir",
    "dist:desktop": "npm run build:desktop && npm run verify:origin-worker && electron-builder",
    "dist:desktop:oneclick": "node scripts/run-powershell.mjs scripts/pack-desktop-oneclick.ps1",
    "pack:desktop:oneclick": "node scripts/run-powershell.mjs scripts/pack-desktop-oneclick.ps1 -DirOnly",
    "verify:auto-update-config": "node --experimental-strip-types scripts/verify-auto-update-config.ts",
    "dist:desktop:publish": "node scripts/run-powershell.mjs scripts/release-desktop-local.ps1",
    "release:desktop:local": "node scripts/run-powershell.mjs scripts/release-desktop-local.ps1"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.90.16",
    "electron-updater": "^6.8.3",
    "jszip": "^3.10.1",
    "lucide-react": "^0.554.0",
    "papaparse": "^5.5.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.22",
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.3",
    "vite": "^7.2.4"
  },
  "build": {
    "appId": "com.conductor.desktop",
    "productName": "Conductor",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "compression": "maximum",
    "electronLanguages": [
      "en-US",
      "zh-CN"
    ],
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "desktop-dist/**/*",
      "excel/bin/rust-xls-converter.exe",
      "origin/bin/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build/icons",
        "to": "build/icons"
      }
    ],
    "asar": true,
    "asarUnpack": [
      "excel/bin/rust-xls-converter.exe",
      "origin/bin/**/*"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "chogng",
        "repo": "conductor-update",
        "releaseType": "release"
      }
    ],
    "mac": {
      "icon": "build/icons/icon.icns",
      "category": "public.app-category.utilities",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "icon": "build/icons/icon.ico",
      "artifactName": "Conductor-${version}-windows-${arch}-portable.${ext}",
      "signAndEditExecutable": false,
      "target": [
        "nsis",
        "zip",
        "7z"
      ]
    },
    "nsis": {
      "artifactName": "Conductor-${version}-windows-${arch}-setup.${ext}"
    },
    "linux": {
      "icon": "build/icons/icon.png",
      "category": "Utility",
      "target": [
        "AppImage",
        "deb"
      ]
    }
  }
}
