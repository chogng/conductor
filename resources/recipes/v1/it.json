{
  "id": "builtin.currentTime.it",
  "version": 1,
  "priority": 85,
  "label": "Detected IT",
  "dataRange": {
    "kind": "detectedDataRegion"
  },
  "blockPartition": {
    "kind": "measurementBlocks",
    "select": "each",
    "minConfidence": 0.75
  },
  "withinBlock": {
    "physicalLayout": "xyyyy",
    "rowRange": "block.dataRange"
  },
  "seriesPartition": {
    "kind": "none"
  },
  "logicalRelation": "oneX-manyY",
  "domain": {
    "family": "it",
    "minConfidence": 0.75
  },
  "roles": {
    "x": {
      "roleAny": [
        "time"
      ],
      "canonicalUnit": "s",
      "count": "one"
    },
    "y": {
      "roleAny": [
        "id",
        "current"
      ],
      "canonicalUnit": "A",
      "count": "oneOrMore"
    }
  },
  "stopOnError": false
}
