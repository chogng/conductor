{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowImportingTsExtensions": true,
    "types": ["node"],
    "strict": false,
    "noEmit": true
  },
  "include": [
    "../build/lib/**/*.ts",
    "../build/npm/**/*.ts",
    "../build/win32/**/*.ts",
    "../scripts/**/*.ts",
    "./cs/server/node/**/*.ts",
    "../vite.config.ts"
  ]
}
